# ============================================================
# EzBot_IA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# NUNCA suba o arquivo .env para o GitHub!
# ============================================================

# === SERVIDOR MINECRAFT (PRIVADO) ===
MINECRAFT_HOST=seu.servidor.aqui
MINECRAFT_PORT=25565
BOT_NAME=SeuNickDoBot

# === IAs (em ordem de prioridade — adicione as que tiver) ===
# 1. Cerebras (cloud.cerebras.ai)
CEREBRAS_API_KEY=

# 2. Groq (console.groq.com)
GROQ_API_KEY=

# 3. Mistral (console.mistral.ai)
MISTRAL_API_KEY=

# 4. OpenRouter (openrouter.ai)
OPENROUTER_API_KEY=

# 5. DeepSeek (platform.deepseek.com)
DEEPSEEK_API_KEY=

# 6. xAI Grok (console.x.ai)
XAI_API_KEY=

# 7. OpenAI / ChatGPT (platform.openai.com)
OPENAI_API_KEY=

# 8. Anthropic / Claude (console.anthropic.com)
ANTHROPIC_API_KEY=

# 9. Google Gemini — SEMPRE O ÚLTIMO (aistudio.google.com)
GOOGLE_AI_API_KEY=

# === LOGS POR EMAIL (opcional) ===
# EMAIL_FROM=seuemail@gmail.com
# EMAIL_TO=seuemail@gmail.com
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=seuemail@gmail.com
# EMAIL_SMTP_PASS=sua_senha_de_app_gmail
